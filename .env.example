DATABASE_URL=postgresql://postgres:postgres@localhost:5432/calmcue
# Use quotes if the key contains = (e.g. AIRIA_API_KEY="ak-...")
AIRIA_API_KEY=
# Airia Agent Pipeline (Agent Settings → Interfaces → API). Uses X-API-KEY and body { userInput, asyncOutput: false }
AIRIA_PIPELINE_URL=https://api.airia.ai/v2/PipelineExecution/YOUR_AGENT_GUID
# Optional: OpenAI-compatible gateway (if not using Pipeline)
# AIRIA_OPENAI_BASE_URL=https://gateway.airia.ai/openai/v1
MODULATE_API_KEY=
NEXT_PUBLIC_APP_NAME=CalmCue

# Focus Mode recap → Discord (optional; app works without it)
DISCORD_WEBHOOK_URL=

# Optional: Airia AgentCard registration (feature flag)
# AIRIA_ENABLE_AGENTCARD=false
